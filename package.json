{
  "name": "wdio-cucumber-e2e-test",
  "type": "module",
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/node": "^25.1.0",
    "@wdio/allure-reporter": "^9.24.0",
    "@wdio/cli": "^9.23.2",
    "@wdio/cucumber-framework": "^9.23.2",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/spec-reporter": "^9.23.2",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "expect-webdriverio": "^5.6.4",
    "prettier": "^3.8.1",
    "winston": "^3.19.0"
  },
  "scripts": {
    "demo": "cross-env DEBUG=Y && cross-env npx wdio ./wdio.conf.ts --cucumberOpts.tagExpression='@demo'",
    "test:demo": "cross-env DEBUG=Y && npx wdio config/wdio.test.conf.ts --cucumberOpts.tagExpression='@demo'",
    "test:debug": "cross-env DEBUG=N && cross-env HEADLESS=N && npx wdio config/wdio.test.conf.ts --cucumberOpts.tagExpression=@debug",
    "smoke": "cross-env DEBUG=N && cross-env HEADLESS=Y && npx wdio wdio.conf.ts --cucumberOpts.tagExpression=@smoke",
    "pretty": "prettier --write .",
    "all": "npx wdio ./wdio.conf.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
